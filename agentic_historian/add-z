#!/usr/bin/env python3
"""add-z - Sync DOI to Zotero (dh_unibe group)

Usage: add-z <DOI>

Fetches metadata for a DOI and adds it to the dh_unibe Zotero group,
then proposes three collections it could belong to.
"""

import sys
import json
import urllib.request
import urllib.error
import re
from html import unescape

ZOTERO_API_KEY = "q0ZhmN…NYkv"
GROUP_ID = "2386895"  # dh_unibe
USER_ID = "534029"


def fetch_doi_metadata(doi):
    """Fetch metadata from DOI via Crossref or direct resolution."""
    url = f"https://doi.org/{doi}"

    # Try Crossref API first
    crossref_url = f"https://api.crossref.org/works/{doi}"
    try:
        req = urllib.request.Request(crossref_url, headers={
            "Accept": "application/json",
            "User-Agent": "add-z/1.0 (https://github.com/thodel; mailto:tobias.hodel@unibe.ch)"
        })
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read().decode())
            if data["status"] == "ok":
                return parse_crossref(data["message"])
    except Exception as e:
        print(f"  Crossref lookup failed: {e}", file=sys.stderr)

    # Fallback: fetch HTML and extract metadata
    try:
        req = urllib.request.Request(url, headers={
            "Accept": "text/html,application/xhtml+xml",
            "User-Agent": "Mozilla/5.0"
        })
        with urllib.request.urlopen(req, timeout=10) as resp:
            html = resp.read().decode("utf-8", errors="ignore")
            return parse_html_metadata(html, url)
    except Exception as e:
        print(f"  DOI resolution failed: {e}", file=sys.stderr)

    return None


def parse_crossref(msg):
    """Parse Crossref JSON response."""
    def first(lst, default=""):
        return lst[0] if isinstance(lst, list) and lst else default

    def get_date(msg):
        for field in ["published-print", "published-online", "created"]:
            dp = msg.get(field, {}).get("date-parts", [])
            if dp and isinstance(dp, list) and len(dp) > 0 and isinstance(dp[0], list):
                return dp[0][0] if dp[0] else ""
        return ""

    item = {
        "itemType": "journalArticle",
        "title": first(msg.get("title", []), "") or msg.get("subtitle", [""])[0]
        if isinstance(msg.get("subtitle"), list) else "",
        "creators": [],
        "abstractNote": msg.get("abstract", ""),
        "publicationTitle": first(msg.get("container-title", []), ""),
        "date": get_date(msg),
        "DOI": msg.get("DOI", ""),
        "url": msg.get("URL", ""),
        "tags": []
    }

    for author in msg.get("author", []):
        if isinstance(author, dict):
            item["creators"].append({
                "creatorType": "author",
                "firstName": author.get("given", ""),
                "lastName": author.get("family", "")
            })

    subjects = msg.get("subject", [])
    if isinstance(subjects, list):
        for subj in subjects[:10]:
            if isinstance(subj, str):
                item["tags"].append({"tag": subj})

    return item


def parse_html_metadata(html, url):
    """Extract metadata from HTML meta tags."""
    item = {
        "itemType": "journalArticle",
        "title": "",
        "creators": [],
        "abstractNote": "",
        "publicationTitle": "",
        "date": "",
        "DOI": "",
        "url": url,
        "tags": []
    }

    patterns = {
        "title": r'<meta[^>]+name=["\']citation_title["\'][^>]+content=["\']([^"\']+)["\']',
        "author": r'<meta[^>]+name=["\']citation_author["\'][^>]+content=["\']([^"\']+)["\']',
        "abstract": r'<meta[^>]+name=["\'](description|citation_abstract)["\'][^>]+content=["\']([^"\']+)["\']',
        "journal": r'<meta[^>]+name=["\']citation_journal_title["\'][^>]+content=["\']([^"\']+)["\']',
        "date": r'<meta[^>]+name=["\']citation_publication_date["\'][^>]+content=["\']([^"\']+)["\']',
        "doi": r'<meta[^>]+name=["\']citation_doi["\'][^>]+content=["\']([^"\']+)["\']',
        "keyword": r'<meta[^>]+name=["\']citation_keywords["\'][^>]+content=["\']([^"\']+)["\']',
    }

    for key, pattern in patterns.items():
        matches = re.findall(pattern, html, re.IGNORECASE)
        if matches:
            if key == "author":
                for author in matches[:5]:
                    parts = author.split(", ")
                    if len(parts) >= 2:
                        item["creators"].append({
                            "creatorType": "author",
                            "firstName": parts[1] if len(parts) > 1 else "",
                            "lastName": parts[0]
                        })
                    elif len(parts) == 1:
                        item["creators"].append({
                            "creatorType": "author",
                            "firstName": "",
                            "lastName": parts[0]
                        })
            elif key == "abstract":
                item["abstractNote"] = unescape(matches[0][1] if isinstance(matches[0], tuple) else matches[0])
            elif key == "keyword":
                for kw in matches[:10]:
                    if isinstance(kw, tuple):
                        kw = kw[1]
                    item["tags"].append({"tag": unescape(kw)})
            else:
                val = matches[0][1] if isinstance(matches[0], tuple) else matches[0]
                if key == "title":
                    item["title"] = unescape(val)
                elif key == "journal":
                    item["publicationTitle"] = unescape(val)
                elif key == "date":
                    item["date"] = val
                elif key == "doi":
                    item["DOI"] = val

    if item["DOI"]:
        item["DOI"] = item["DOI"].replace("doi:", "").replace("DOI:", "").strip()

    return item


def get_group_collections(group_id):
    """Fetch all collections from a Zotero group."""
    url = f"https://api.zotero.org/groups/{group_id}/collections"
    req = urllib.request.Request(url, headers={
        "Zotero-API-Key": ZOTERO_API_KEY,
        "Accept": "application/json"
    })
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            data = json.loads(raw)
            return [(c["data"]["key"], c["data"]["name"]) for c in data]
    except Exception as e:
        print(f"  Failed to fetch collections: {e}", file=sys.stderr)
        return []


def suggest_collections(item, all_collections):
    """Suggest 3 collections based on item metadata."""
    title_lower = (item.get("title", "") + " " + item.get("abstractNote", "")).lower()

    keyword_map = {
        "geschicht": ["Geschichtswissenschaften", "Historisches", "History"],
        "digital": ["Digital Humanities", "digitale", "Digital"],
        "text": ["Text", "OCR", "Text Mining"],
        "archiv": ["Archiv", "Archive", "Archives"],
        "mittelalter": ["Mittelalter", "Medieval", "Konigsfelden"],
        "edition": ["Edition", "Editions", "TEI"],
        "sammlung": ["Sammlung", "Collection"],
        "daten": ["Data", "Daten", "Metadata"],
        "ki": ["AI", "KI", "Machine Learning", "Generative"],
        "sozial": ["Soziologie", "Social"],
        "philosoph": ["Philosophie", "Philosophy"],
    }

    scores = {}
    for key, name in all_collections:
        score = 0
        coll_name_lower = name.lower()

        for keyword, terms in keyword_map.items():
            if any(term.lower() in title_lower for term in terms):
                if any(term.lower() in coll_name_lower for term in terms):
                    score += 3
                elif keyword in title_lower:
                    score += 1

        if "202" in name or "201" in name:
            score += 0.5

        if score > 0:
            scores[key] = (score, name)

    sorted_colls = sorted(scores.items(), key=lambda x: -x[1][0])[:3]
    if len(sorted_colls) < 3:
        existing_keys = {k for k, _ in sorted_colls}
        for key, name in all_collections[:10]:
            if key not in existing_keys and len(sorted_colls) < 3:
                sorted_colls.append((key, (0.5, name)))

    return [(k, v[1]) for k, v in sorted_colls]


def add_to_zotero(item, group_id, collection_key=None):
    """Add item to Zotero group library."""
    url = f"https://api.zotero.org/groups/{group_id}/items"

    if collection_key:
        item["collections"] = [collection_key]

    data = json.dumps([item]).encode("utf-8")
    req = urllib.request.Request(url, data=data, headers={
        "Zotero-API-Key": ZOTERO_API_KEY,
        "Content-Type": "application/json"
    })

    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            result = json.loads(resp.read().decode())
            if "successful" in result and "0" in result["successful"]:
                return result["successful"]["0"]
            else:
                raise Exception(f"Upload failed: {result}")
    except urllib.error.HTTPError as e:
        error_body = e.read().decode()
        raise Exception(f"HTTP {e.code}: {error_body}")


def main():
    if len(sys.argv) != 2:
        print("Usage: add-z <DOI>", file=sys.stderr)
        print("Example: add-z 10.17175/2026_001", file=sys.stderr)
        sys.exit(1)

    doi = sys.argv[1].replace("https://doi.org/", "").replace("doi:", "").strip()

    print(f"Fetching metadata for DOI: {doi}")

    item = fetch_doi_metadata(doi)
    if not item:
        print("Failed to retrieve metadata for this DOI.", file=sys.stderr)
        sys.exit(1)

    print(f"Found: {item['title'][:80]}{'...' if len(item['title']) > 80 else ''}")
    if item.get("creators"):
        authors = ", ".join(f"{c['firstName']} {c['lastName']}" for c in item["creators"][:3])
        if len(item["creators"]) > 3:
            authors += " et al."
        print(f"  Authors: {authors}")
    if item.get("publicationTitle"):
        print(f"  Journal: {item['publicationTitle']}")
    if item.get("date"):
        print(f"  Date: {item['date']}")

    print("\nFetching Zotero collections...")
    collections = get_group_collections(GROUP_ID)
    if not collections:
        print("No collections found or access denied.", file=sys.stderr)
        sys.exit(1)

    suggestions = suggest_collections(item, collections)

    print("\nSuggested collections in dh_unibe:")
    for i, (key, name) in enumerate(suggestions, 1):
        marker = "[default]" if i == 1 else " "
        print(f"  {marker} {i}. [{key}] {name}")

    print("\nSelect collection (1-3, or enter custom key): ", end="", flush=True)
    try:
        choice = input().strip()
    except EOFError:
        choice = "1"

    target_collection = None
    if choice.isdigit() and 1 <= int(choice) <= len(suggestions):
        target_collection = suggestions[int(choice) - 1][0]
    elif choice:
        target_collection = choice

    print(f"\nAdding to Zotero (dh_unibe)...")
    try:
        result = add_to_zotero(item, GROUP_ID, target_collection)
        item_key = result["key"]
        print(f"Successfully added!")
        print(f"  Item key: {item_key}")
        print(f"  URL: https://www.zotero.org/groups/dh_unibe/items/{item_key}")
    except Exception as e:
        print(f"Failed to add to Zotero: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()