# GPUStack (unibe) — copy to .env.gpustack at the repo root and fill in.
# NEVER commit the real key. .env.gpustack is gitignored.
GPUSTACK_API_KEY=your_api_key_here
GPUSTACK_BASE_URL=https://gpustack.unibe.ch/v1

# Role-based model routing
GPUSTACK_MODEL_VISION=qwen3-vl-30b-a3b-instruct      # Agent A (HTR) + Agent B (description)
GPUSTACK_MODEL_TEXT=gpt-oss-120b                      # Agent C (NER) + corpus/meta + reconcile
GPUSTACK_MODEL_ORCHESTRATOR=minimax-m2.7             # future NL/SitL orchestrator (WP1)

# Retrieval (planned: hub linking + corpus semantic analysis)
GPUSTACK_MODEL_EMBEDDING=qwen3-embedding-0.6b
GPUSTACK_MODEL_RERANKER=jina-reranker-v2-base-multilingual

# gpt-oss-120b is a reasoning model — keep this budget generous
GPUSTACK_TEXT_MAX_TOKENS=4096

# HTR VLM anti-repetition decoding (#275). Applied only to transcription calls.
VLM_FREQUENCY_PENALTY=0.2
VLM_PRESENCE_PENALTY=0.0

# HLS-DHS linking (offline, from a local dump). Drop your dump at the path below
# (see knowledge_hub/hub.py for the JSON format), then set ENABLE_HLS_LOOKUP=true.
ENABLE_HLS_LOOKUP=false
HLS_DATA_PATH=knowledge_hub/data/hls.json

# SwitchDrive ingestion (WebDAV app password). Used by the /pull command.
SWITCHDRIVE_URL=https://drive.switch.ch/remote.php/webdav
SWITCHDRIVE_USER=
SWITCHDRIVE_PASS=
SWITCHDRIVE_REMOTE_DIR=agentic_historian_hotfolder
